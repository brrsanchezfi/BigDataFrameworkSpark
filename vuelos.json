{
  "_doc": "Tabla externa de vuelos crudos — usa variables del bundle y del env",
  "catalog": "${bundle.targets.dev.catalog}",
  "schema": "aeronautica",
  "name": "vuelos_raw",
  "type": "EXTERNAL",
  "format": "DELTA",
  "comment": "Datos crudos de vuelos recibidos desde el sistema fuente",
  "owner": "data-engineers",
  "location": "${ext.base_path}/aeronautica/vuelos_raw",
  "columns": [
    {
      "name": "vuelo_id",
      "type": "STRING",
      "comment": "Identificador único del vuelo",
      "nullable": false
    },
    {
      "name": "origen",
      "type": "STRING",
      "comment": "Código IATA aeropuerto origen"
    },
    {
      "name": "destino",
      "type": "STRING",
      "comment": "Código IATA aeropuerto destino"
    },
    {
      "name": "retraso_min",
      "type": "INTEGER",
      "comment": "Minutos de retraso (0 = a tiempo)"
    },
    {
      "name": "fecha",
      "type": "DATE",
      "comment": "Fecha del vuelo"
    },
    {
      "name": "aerolinea",
      "type": "STRING",
      "comment": "Código IATA de la aerolínea"
    },
    {
      "name": "cargado_en",
      "type": "TIMESTAMP",
      "comment": "Timestamp de ingesta",
      "default": "current_timestamp()"
    }
  ],
  "partitions": [
    "fecha"
  ],
  "clustering": {
    "columns": [
      "origen",
      "destino"
    ]
  },
  "properties": {
    "delta.autoOptimize.optimizeWrite": "true",
    "delta.autoOptimize.autoCompact": "true",
    "quality": "raw",
    "owner_team": "data-engineering"
  },
  "permissions": [
    {
      "action": "SELECT",
      "principal": "analysts-group",
      "operation": "GRANT"
    },
    {
      "action": "MODIFY",
      "principal": "etl-service-account",
      "operation": "GRANT"
    },
    {
      "action": "ALL PRIVILEGES",
      "principal": "data-engineers",
      "operation": "GRANT"
    }
  ],
  "alterations": [
    {
      "type": "ADD_COLUMN",
      "name": "tiempo_vuelo_min",
      "comment": "Duración real del vuelo en minutos",
      "type_col": "INTEGER"
    },
    {
      "type": "SET_TBLPROPERTIES",
      "properties": {
        "delta.columnMapping.mode": "name",
        "quality": "bronze"
      }
    }
  ]
}